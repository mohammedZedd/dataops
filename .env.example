# ════════════════════════════════════════════════════════════════════════════
#  .env.example — Source unique de vérité pour la configuration ComptaFlow
#  Copier ce fichier en .env et remplir les valeurs réelles.
#
#  IMPORTANT : Ne jamais commiter le fichier .env — il est dans .gitignore.
#  Ne jamais mettre de vraies clés dans ce fichier .env.example.
# ════════════════════════════════════════════════════════════════════════════

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=payfit
POSTGRES_USER=payfit
POSTGRES_PASSWORD=payfit

# ─── pgAdmin ──────────────────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin

# ─── App ──────────────────────────────────────────────────────────────────────
# En dev local, pointer vers localhost. Docker réécrit cette valeur automatiquement.
DATABASE_URL=postgresql://<postgres_user>@localhost:5432/payfit
DEBUG=true
FRONTEND_URL=http://localhost:5173

# Générer avec : openssl rand -hex 32
JWT_SECRET_KEY=<a-long-random-secret>
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ─── AWS ──────────────────────────────────────────────────────────────────────
# Créer un utilisateur IAM dédié dans AWS Console → IAM → Users
# Permissions requises :
#   - s3:GetObject, s3:PutObject, s3:DeleteObject, s3:ListBucket  sur arn:aws:s3:::dataopsdepot/*
#   - ses:SendEmail, ses:SendRawEmail                              sur *
#   - textract:AnalyzeDocument, textract:DetectDocumentText        sur *
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-3
S3_BUCKET_NAME=dataopsdepot
SES_SENDER_EMAIL=noreply@dataops.ma

# ─── Email SMTP (alternative à AWS SES) ───────────────────────────────────────
# Priorité : SMTP si SMTP_HOST est défini, sinon AWS SES automatiquement.
# Laisser vide pour utiliser SES.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
